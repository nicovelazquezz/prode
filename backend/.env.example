NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://prode:prode_dev_pwd@localhost:5433/prode
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
MP_WEBHOOK_SECRET=...
# WhatsApp gateway (Baileys sidecar).
#
#   - DEV LOCAL: dejá `https://example.com` (o `http://localhost:9999` o
#     cualquier URL con hostname placeholder). El WhatsappService detecta
#     el placeholder y entra en modo "dev-simulate": loguea el mensaje
#     en stdout y resuelve OK sin pegarle a nada. No necesitás levantar
#     el sidecar para correr el flujo en local.
#   - DOKPLOY/PROD: apuntar al servicio interno del compose:
#     `WHATSAPP_API_URL=http://prode-wa-backend:3001`. El token va
#     compartido entre el gateway (wa-backend) y el backend — el gateway
#     valida `Authorization: Bearer ${WHATSAPP_API_TOKEN}` en `/send`.
WHATSAPP_API_URL=https://example.com
WHATSAPP_API_TOKEN=dev-placeholder-not-used-while-url-is-placeholder
ADMIN_WHATSAPP_NUMBER=5492914xxxxxxx
EMAIL_FROM=noreply@prodeplus.com
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
TURNSTILE_SECRET_KEY=
SENTRY_DSN=

# Admin bootstrap (consumed by seed-config.ts on first install).
# DNI: 7–9 digits. Password: min 8 chars, change after first login.
ADMIN_DEFAULT_DNI=
ADMIN_DEFAULT_PASSWORD=
