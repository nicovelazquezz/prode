# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Dev-only pages (mock checkout, etc.) — quedan locales, NO se deployan
# a producción. Mantiene la app de prod libre de superficies de bypass
# que puedan activarse por error.
/app/dev/

# vercel
.vercel

# serwist (generated by `next build`)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
